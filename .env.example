# --- Database ---
# Local Postgres connection string. Copy this file to .env and fill real values.
DATABASE_URL="postgresql://user:password@localhost:5432/member_tracker?schema=public"

# --- WhatsApp ---
# simulate = log messages only (free, no account).
# live = forward sends to the always-on WhatsApp worker (npm run wa:worker).
WHATSAPP_MODE="simulate"
# Where the WhatsApp worker listens (only used in live mode).
WHATSAPP_WORKER_URL="http://localhost:4000"

# --- App ---
NODE_ENV="development"
